# Database
DATABASE_URL=postgresql://hamrotourist:hamrotourist_dev@localhost:5432/hamrotourist
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=hamrotourist
DATABASE_PASSWORD=hamrotourist_dev
DATABASE_NAME=hamrotourist

# Redis
REDIS_URL=redis://localhost:6379

# Auth (RS256 JWT)
JWT_PRIVATE_KEY=<generate with: openssl genrsa -out private.pem 2048>
JWT_PUBLIC_KEY=<generate with: openssl rsa -in private.pem -pubout -out public.pem>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=hamrotourist-media

# Domain Service
DOMAIN_VERIFICATION_POLL_INTERVAL_MS=60000
DOMAIN_VERIFICATION_TIMEOUT_MS=86400000
FALLBACK_ORIGIN=proxy.hamrotourist.com

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:4000

# ISR
REVALIDATE_SECRET=dev-revalidate-secret

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@hamrotourist.com
RESEND_FROM_NAME=Hamro Tourist

# Service Ports
AUTH_SERVICE_PORT=4001
TENANT_SERVICE_PORT=4002
PRODUCT_SERVICE_PORT=4003
WEBSITE_BUILDER_SERVICE_PORT=4004
MEDIA_SERVICE_PORT=4005
DOMAIN_SERVICE_PORT=4006
CRM_SERVICE_PORT=4007
NOTIFICATION_SERVICE_PORT=4008
API_GATEWAY_PORT=4000
