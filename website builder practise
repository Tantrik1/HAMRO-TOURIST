6.3 Tenant Resolution MiddlewareTypeScript// middleware.ts — runs at Cloudflare edge via Next.js
export function middleware(request: NextRequest) {
  const hostname = request.headers.get('host') || '';

  // adventures.hamrotourist.com → tenantSlug = 'adventures'
  // www.nepaladventures.com     → lookup in domain table
  const tenantSlug = hostname.replace('.hamrotourist.com', '');

  const response = NextResponse.next();
  response.headers.set('x-tenant-slug', tenantSlug);
  response.headers.set('x-hostname', hostname);

  // Preview mode via token
  const previewToken = request.nextUrl.searchParams.get('preview_token');
  if (previewToken) {
    response.headers.set('x-preview-token', previewToken);
  }
  return response;
}
6.4 Section RendererThe section renderer is the heart of the website renderer — it maps a section type string and its JSONB configuration to the correct React component from the active theme:TypeScript// section-renderer.tsx
import * as AdventureBold from '@hamrotourist/theme-adventure-bold';
import * as HeritageClassic from '@hamrotourist/theme-heritage-classic';
// ... all 6 themes

const THEME_MAP: Record<string, Record<string, React.ComponentType<any>>> = {
  'adventure-bold':    AdventureBold.sections,
  'heritage-classic':  HeritageClassic.sections,
  // ...
};

export function renderSections(themeId: string, sections: PageSection[]) {
  const themeComponents = THEME_MAP[themeId];
  return sections
    .filter(s => s.is_visible)
    .sort((a, b) => a.sort_order - b.sort_order)
    .map(section => {
      const Component = themeComponents[section.section_type];
      if (!Component) return null;
      return <Component key={section.id} {...section.content} settings={section.settings} />;
    });
}
6.5 Rendering StrategyPage TypeStrategy & ReasoningHome PageISR (Incremental Static Regeneration) with 60s revalidate + on-demand revalidation on publishPackage ListingSSR with edge caching — packages change frequently, need real-time availabilityPackage DetailISR per slug with 5min revalidate + on-demand bust when package is updatedDestination PagesSSG at build time + ISR revalidation when destination data changesCustom PagesISR with 300s revalidate — changes infrequent after publishContact / FormsSSR — must be server-rendered for form submission handlingPreview ModeFully SSR — bypasses all caches, reads draft theme directly from API7. Cloudflare Architecture & Domain Strategy7.1 Subdomain Routing (Default — All Plans)Every agency gets a subdomain under hamrotourist.com immediately upon account creation. This is zero-configuration from the agency's perspective.PropertyValuePattern{agency-slug}.hamrotourist.comDNS RecordWildcard A/CNAME: *.hamrotourist.com → website-renderer cluster IPCloudflare ConfigWildcard SSL certificate via Cloudflare Universal SSL (auto-renewed)RoutingCloudflare Worker reads hostname, passes as x-tenant-slug header to rendererCachingCloudflare caches ISR pages at edge. Cache-Control: s-maxage=60, stale-while-revalidatePerformanceCloudflare Argo Smart Routing + HTTP/3 + Brotli compression enabled by default7.2 Custom Domain Routing (Premium Plans)Premium agencies can connect their own domain (e.g., www.nepaladventures.com). The workflow is fully automated via Cloudflare API:Agency enters custom domain in admin panel → domain-service validates formatSystem generates a DNS TXT verification token and shows it to the agencyAgency adds TXT record at their DNS registrar: _hamrotourist-verify.domain.com → <token>Cloudflare API polls DNS (every 5 min) until TXT record resolves correctlyOn verification: Cloudflare Zone is created (or Custom Hostname if shared zone), SSL provisionedCloudflare Worker is updated to route custom domain → same renderer with tenant contextDomain status in dashboard updates to ACTIVE with green indicator7.3 Cloudflare Worker LogicJavaScript// cloudflare-worker.js — deployed at Cloudflare edge
addEventListener('fetch', event => event.respondWith(handleRequest(event.request)));

async function handleRequest(request) {
  const url = new URL(request.url);
  const hostname = url.hostname;

  let tenantSlug;

  if (hostname.endsWith('.hamrotourist.com')) {
    // Subdomain routing
    tenantSlug = hostname.replace('.hamrotourist.com', '');
  } else {
    // Custom domain — lookup from KV store (synced from DB on domain changes)
    tenantSlug = await DOMAIN_MAP.get(hostname);
    if (!tenantSlug) return new Response('Agency not found', { status: 404 });
  }

  // Forward to website-renderer with tenant context
  const rendererUrl = new URL(request.url);
  rendererUrl.hostname = 'website-renderer.internal.hamrotourist.com';

  const proxiedRequest = new Request(rendererUrl.toString(), {
    method: request.method,
    headers: {
      ...Object.fromEntries(request.headers),
      'x-tenant-slug': tenantSlug,
      'x-original-host': hostname,
    },
    body: request.body
  });
  return fetch(proxiedRequest);
}
7.4 Cloudflare KV for Domain MappingCustom domain → tenant slug mappings are stored in Cloudflare KV for sub-millisecond edge lookup:PropertyValueKV Store NameDOMAIN_MAPKey formatwww.nepaladventures.comValue formatadventures (tenant slug)Sync triggerdomain-service emits event on domain activation/deactivation → Worker syncs KVTTLNo TTL — explicit deletion on domain removalFallbackIf KV miss → query domain-service API with 5s timeout → cache result7.5 Cache Invalidation on PublishWhen an agency publishes changes, the publishing pipeline automatically busts Cloudflare cache:TypeScript// cache-invalidation.service.ts
async invalidateForTenant(tenantSlug: string, paths: string[] = ['/*']) {
  const hostname = ${tenantSlug}.hamrotourist.com;

  // 1. Purge Cloudflare cache for subdomain
  await this.cloudflare.purgeCache({
    zone_id: process.env.CF_ZONE_ID,
    files: paths.map(p => https://${hostname}${p})
  });

  // 2. Trigger Next.js ISR revalidation
  await fetch(${process.env.RENDERER_URL}/api/revalidate, {
    method: 'POST',
    headers: { 'x-revalidate-secret': process.env.REVALIDATE_SECRET },
    body: JSON.stringify({ tenantSlug, paths })
  });

  // 3. If custom domain active, purge that too
  const customDomain = await this.domainService.getActiveDomain(tenantSlug);
  if (customDomain) {
    await this.cloudflare.purgeCache({
      zone_id: customDomain.cloudflare_zone_id,
      files: paths.map(p => https://${customDomain.custom_domain}${p})
    });
  }
}
