export async function PackageGrid({ settings, content }: PackageGridProps) {
  // Dynamic fetch at render time (SSR/ISR)
  const packages = await fetch(`${BUILDER_API}/data/packages?${
    new URLSearchParams({
      tenantId: context.tenantId,
      regionId: settings.filterRegion || '',
      countryId: settings.filterCountry || '',
      category:  settings.filterCategory || '',
      featured:  settings.showFeaturedOnly ? 'true' : '',
      limit:     settings.itemCount || '12',
      sortBy:    settings.sortBy || 'popularity',
    })
  }`).then(r => r.json());

  return (
    <section className="package-grid">
      <PackageFilter regions={regions} categories={categories} />
      <div className="grid grid-cols-3 gap-6">
        {packages.map(pkg => <PackageCard key={pkg.id} package={pkg} />)}
      </div>
    </section>
  );
}
