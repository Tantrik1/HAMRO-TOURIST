.chaos-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,80,80,0.5); margin-bottom: 0.6rem; }
.chaos-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.chaos-tag { background: rgba(255,50,50,0.1); color: rgba(255,100,90,0.7); padding: 0.25rem 0.7rem; border-radius: 100px; font-size: 0.7rem; border: 1px solid rgba(255,50,50,0.15); }

/* S3: COST OF WAITING */
.cost { background: var(--off-white); padding: 7rem 0; }
.cost-center { text-align: center; }
.cost-toggles { display: flex; background: rgba(43,57,144,0.08); border-radius: 10px; width: fit-content; margin: 2.5rem auto 0; overflow: hidden; }
.cost-btn { padding: 0.6rem 1.5rem; font-size: 0.85rem; border: none; background: transparent; cursor: pointer; color: var(--muted); font-family: 'Barlow', sans-serif; font-weight: 600; transition: all 0.3s; letter-spacing: 0.02em; }
.cost-btn.active { background: var(--cobalt); color: var(--white); border-radius: 8px; }
.cost-amount-wrap { margin: 2.5rem auto; }
.cost-prefix { font-size: 1.1rem; color: var(--muted); margin-bottom: 0.5rem; }
.cost-amount { font-family: 'Barlow Condensed', sans-serif; font-size: clamp(4rem, 9vw, 8rem); font-weight: 900; color: var(--orange); line-height: 1; letter-spacing: -0.02em; }
.cost-suffix { font-size: 0.9rem; color: var(--muted); margin-top: 0.5rem; }
.cost-note { font-size: 0.8rem; color: var(--muted); margin-top: 1.5rem; max-width: 400px; margin-left: auto; margin-right: auto; }
.cost-breakdown { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 3.5rem; max-width: 700px; margin-left: auto; margin-right: auto; }
.cbreak { background: var(--white); border-radius: 16px; padding: 1.5rem; text-align: center; border: 1px solid var(--border); }
.cbreak-val { font-family: 'DM Mono', monospace; font-size: 1.4rem; color: var(--cobalt); font-weight: 500; }
.cbreak-label { font-size: 0.75rem; color: var(--muted); margin-top: 0.3rem; }

/* S4: THE SHIFT */
.shift { background: var(--cobalt); padding: 7rem 0; }
.shift-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; margin-top: 4rem; }
.comp-col { border-radius: 20px; padding: 2rem; }
.comp-before { background: rgba(255,50,50,0.06); border: 1px solid rgba(255,50,50,0.15); }
.comp-after { background: rgba(232,67,26,0.1); border: 2px solid rgba(232,67,26,0.3); }
.comp-head { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 1.5rem; }
.comp-head.bad { color: rgba(255,100,90,0.8); }
.comp-head.good { color: var(--orange-mid); }
.comp-row { display: flex; align-items: flex-start; gap: 0.75rem; margin-bottom: 1rem; }
.comp-ico { width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; flex-shrink: 0; margin-top: 2px; }
.comp-ico.bad { background: rgba(255,50,50,0.18); }
.comp-ico.good { background: rgba(232,67,26,0.2); }
.comp-text { font-size: 0.88rem; color: rgba(255,255,255,0.6); line-height: 1.5; font-weight: 300; }

/* S6: PRODUCT TABS */
.product { background: var(--white); padding: 7rem 0; }
.tab-nav { display: flex; gap: 0; background: var(--off-white); border-radius: 12px; width: fit-content; margin: 3rem 0 0; overflow: hidden; border: 1px solid var(--border); }
.tab-btn { padding: 0.75rem 1.5rem; font-size: 0.88rem; border: none; background: transparent; cursor: pointer; color: var(--muted); font-family: 'Barlow', sans-serif; font-weight: 600; transition: all 0.3s; white-space: nowrap; }
.tab-btn.active { background: var(--cobalt); color: var(--white); border-radius: 10px; }
.tab-content { margin-top: 2.5rem; }
.tab-panel { display: none; }
.tab-panel.active { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
.tab-panel-title { font-family: 'Barlow Condensed', sans-serif; font-size: 2rem; font-weight: 800; color: var(--cobalt-dark); text-transform: uppercase; margin-bottom: 1rem; }
.tab-panel-desc { font-size: 1rem; color: var(--muted); line-height: 1.7; font-weight: 300; }
.tab-features { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
.tab-feat { display: flex; align-items: center; gap: 0.75rem; font-size: 0.9rem; color: var(--text); }
.tab-feat::before { content:'→'; color: var(--orange); font-weight: 700; flex-shrink: 0; }
.tab-visual { background: var(--off-white); border-radius: 20px; padding: 2rem; border: 1px solid var(--border); min-height: 280px; display: flex; align-items: center; justify-content: center; }
.tab-visual-inner { text-align: center; }
.tab-icon { font-size: 4rem; margin-bottom: 1rem; }
.tab-visual-title { font-family: 'Barlow Condensed', sans-serif; font-size: 1.3rem; font-weight: 700; color: var(--cobalt-dark); text-transform: uppercase; }
.tab-visual-sub { font-size: 0.82rem; color: var(--muted); margin-top: 0.5rem; }

/* S7: FEATURES GRID */
.features { background: var(--off-white); padding: 7rem 0; }
.feat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 4rem; }
.feat-card {
  background: var(--white); border-radius: 20px; padding: 2rem;
  border: 1px solid var(--border); transition: all 0.35s;
  position: relative; overflow: hidden;
}
.feat-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--orange); transform: scaleX(0); transition: transform 0.3s;
  transform-origin: left;
}
.feat-card:hover { transform: translateY(-6px); box-shadow: 0 20px 50px rgba(43,57,144,0.1); }
.feat-card:hover::before { transform: scaleX(1); }
