.nav-cta:hover { background: var(--orange-light) !important; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(232,67,26,0.4); }

/* HERO — S1 */
.hero {
  min-height: 100vh; background: var(--cobalt-dark); position: relative;
  display: flex; align-items: center; overflow: hidden;
}
.hero-bg-pattern {
  position: absolute; inset: 0; opacity: 0.06;
