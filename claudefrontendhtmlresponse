.hcard-tags { display: flex; gap: 0.5rem; margin-top: 1rem; flex-wrap: wrap; }
.hcard-tag { background: rgba(232,67,26,0.15); color: var(--orange-mid); padding: 0.25rem 0.8rem; border-radius: 100px; font-size: 0.7rem; font-weight: 500; border: 1px solid rgba(232,67,26,0.2); }
.hcard-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-top: 1.5rem; }
