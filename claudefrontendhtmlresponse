.feat-icon { font-size: 2rem; margin-bottom: 1.2rem; display: block; }
.feat-title { font-family: 'Barlow Condensed', sans-serif; font-size: 1.25rem; font-weight: 800; color: var(--cobalt-dark); text-transform: uppercase; margin-bottom: 0.6rem; letter-spacing: 0.01em; }
.feat-desc { font-size: 0.88rem; color: var(--muted); line-height: 1.6; font-weight: 300; }

/* S8: TESTIMONIALS */
.testimonials { background: var(--cobalt-dark); padding: 7rem 0; }
.testi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 4rem; }
.testi-card {
