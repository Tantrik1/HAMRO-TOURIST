<script>
// NAV scroll
window.addEventListener('scroll', () => {
  document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 60);
});

// Reveal on scroll
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.12 });
reveals.forEach(el => observer.observe(el));

// Cost calculator
const costs = { day: 'रू ५,४८०', week: 'रू ३८,३६०', month: 'रू १,६४,४००', year: 'रू १९,७२,८००' };
function setCost(period, btn) {
  document.getElementById('costAmount').textContent = costs[period];
  document.querySelectorAll('.cost-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

// Product tabs
function setTab(id, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  btn.classList.add('active');
}

// FAQ toggle
function toggleFaq(btn) {
  const item = btn.closest('.faq-item');
  const wasOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
  if (!wasOpen) item.classList.add('open');
}

// Pricing toggle
let isAnnual = false;
function togglePricing(el) {
  isAnnual = !isAnnual;
  el.classList.toggle('annual', isAnnual);
  document.getElementById('proPrice').textContent = isAnnual ? 'रू ७९९' : 'रू ९९९';
  document.getElementById('scalePrice').textContent = isAnnual ? 'रू १,५९९' : 'रू १,९९९';
  document.getElementById('proPeriod').textContent = isAnnual ? 'per month · billed annually' : 'per month · billed monthly';
  document.getElementById('scalePeriod').textContent = isAnnual ? 'per month · billed annually' : 'per month · billed monthly';
}

// Geography switcher
const geoData = {
  nepal: { title: 'Nepal → Khumbu Region', treks: [['Everest Base Camp','14 days · Moderate–Hard · Sept–Nov','रू ४५,०००/person'],['Gokyo Lakes Trek','12 days · Moderate · Oct–May','रू ३८,०००/person'],['Three Passes Circuit','20 days · Challenging · Mar–May','रू ७२,०००/person']] },
  india: { title: 'India → Uttarakhand', treks: [['Valley of Flowers','6 days · Easy–Moderate · Jun–Oct','रू २५,०००/person'],['Roopkund Trek','9 days · Challenging · May–Jun','रू ३२,०००/person'],['Kedarkantha Summit','6 days · Moderate · Dec–Apr','रू १८,०००/person']] },
  bhutan: { title: 'Bhutan → Paro & Thimphu', treks: [['Druk Path Trek','5 days · Moderate · Mar–May','रू ९५,०००/person'],['Snowman Trek','25 days · Very Hard · Oct–Nov','रू ३,२०,०००/person'],['Tiger Nest Day Hike','1 day · Moderate · All year','रू ३५,०००/person']] },
  tibet: { title: 'Tibet → Lhasa Region', treks: [['Kailash Parikrama','4 days · Challenging · May–Sep','रू १,२०,०००/person'],['Ganden to Samye','5 days · Moderate · Jun–Sep','रू ७५,०००/person']] },
  sri: { title: 'Sri Lanka → Hill Country', treks: [['Adam\'s Peak Climb','1 day · Moderate · Dec–May','रू १५,०००/person'],['Knuckles Range Trek','4 days · Moderate · All year','रू ३५,०००/person'],['Horton Plains Walk','1 day · Easy · All year','रू १२,०००/person']] }
};
function setGeo(id, el) {
  document.querySelectorAll('.geo-region').forEach(r => r.classList.remove('active'));
  el.classList.add('active');
  const d = geoData[id];
  document.getElementById('geoPreviewTitle').textContent = d.title;
  document.getElementById('geoTrekList').innerHTML = d.treks.map(t => `<div class="geo-trek"><div class="geo-trek-name">${t[0]}</div><div class="geo-trek-meta">${t[1]}</div><div class="geo-trek-price">${t[2]}</div></div>`).join('');
}

// FOMO list animation
const fomoItems = document.querySelectorAll('.fomo-item');
let fi = 0;
function showFomo() {
  if (fi < fomoItems.length) { fomoItems[fi].classList.add('appeared'); fi++; setTimeout(showFomo, 600); }
}
const fomoObs = new IntersectionObserver(entries => { if (entries[0].isIntersecting) { showFomo(); fomoObs.disconnect(); } }, { threshold: 0.3 });
fomoObs.observe(document.getElementById('fomoList'));

// Counter animation for stats
function animateCount(el, target, prefix='', suffix='') {
  let start = 0; const dur = 2000; const step = dur / 60;
  const inc = target / (dur / step);
  const timer = setInterval(() => {
    start = Math.min(start + inc, target);
    el.textContent = prefix + Math.round(start).toLocaleString() + suffix;
    if (start >= target) clearInterval(timer);
  }, step);
}
</script>
