  border-radius: 20px; padding: 2rem; transition: all 0.35s;
}
.testi-card:hover { background: rgba(232,67,26,0.06); border-color: rgba(232,67,26,0.2); transform: translateY(-4px); }
.testi-stars { color: var(--orange); font-size: 1rem; margin-bottom: 1.2rem; letter-spacing: 0.1em; }
.testi-quote { font-size: 0.95rem; color: rgba(255,255,255,0.7); line-height: 1.7; font-weight: 300; font-style: italic; margin-bottom: 1.5rem; }
.testi-meta { display: flex; align-items: center; gap: 0.75rem; }
.testi-avatar { width: 42px; height: 42px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 1rem; color: var(--white); flex-shrink: 0; }
.testi-name { font-weight: 600; font-size: 0.88rem; color: var(--white); }
.testi-agency { font-size: 0.75rem; color: rgba(255,255,255,0.4); margin-top: 0.1rem; }

/* S9: FOMO LIVE */
.fomo { background: var(--off-white); padding: 7rem 0; }
.fomo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
.fomo-list { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 2rem; }
.fomo-item {
  display: flex; align-items: center; gap: 1rem; background: var(--white);
  border-radius: 12px; padding: 0.85rem 1.2rem; border: 1px solid var(--border);
  font-size: 0.88rem; color: var(--text); opacity: 0; transform: translateX(-20px);
}
.fomo-item.appeared { opacity: 1; transform: translateX(0); transition: all 0.5s ease; }
.fomo-item-dot { width: 8px; height: 8px; background: var(--orange); border-radius: 50%; flex-shrink: 0; animation: pulse 2s ease infinite; }
.fomo-time { font-family: 'DM Mono', monospace; font-size: 0.72rem; color: var(--muted); margin-left: auto; }
.fomo-counter-block { text-align: center; background: var(--cobalt-dark); border-radius: 24px; padding: 3rem 2rem; }
.fomo-big { font-family: 'Barlow Condensed', sans-serif; font-size: 5rem; font-weight: 900; color: var(--white); line-height: 1; letter-spacing: -0.02em; }
.fomo-big span { color: var(--orange); }
.fomo-big-label { font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 0.75rem; }
